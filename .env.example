# ContextWatch local environment
# Copy to .env and adjust as needed.

ANOMALY_THRESHOLD=0.20
LOG_LEVEL=INFO

# API
API_HOST=0.0.0.0
API_PORT=8000

# Postgres connection (local host)
# DATABASE_URL wins if set.
DATABASE_URL=postgresql://contextwatch:contextwatch@localhost:5432/contextwatch
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=contextwatch
POSTGRES_USER=contextwatch
POSTGRES_PASSWORD=contextwatch

# Vector store backend: memory (default) or postgres
VECTOR_STORE_BACKEND=memory

# Optional model/runtime tuning
EMBEDDING_DIM=384
GRAPH_MAX_DEPTH=3
DETECTION_METHOD=ensemble
